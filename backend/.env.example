# Valley Care Group — Backend Environment Variables
# Copy this file to .env and fill in your own values for local development.
# In production, set these in the Vercel dashboard (Project → Settings → Environment Variables).

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3500

# Secret key for signing JWT tokens — CHANGE THIS before going live!
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret-before-going-live

# Admin panel password (the server hashes this on first start and stores the hash in KV)
# Change this before going live. Minimum 12 characters recommended.
ADMIN_PASSWORD=vcg2025

# Local dev only: after changing ADMIN_PASSWORD, set RESET_ADMIN_HASH=1 and restart once
# so the old bcrypt hash is removed. Then remove this or set to 0.
# RESET_ADMIN_HASH=1

# Set to 'production' when deploying — enables stricter CORS
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Example: https://vcg-frontend.vercel.app,https://www.valleycare.wales
# REQUIRED in production (at least one origin). Leave blank in development.
ALLOWED_ORIGIN=

# ── Resend (enquiry & application emails) ───────────────────────────────────
# https://resend.com — verify your sending domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com
ENQUIRY_NOTIFY_TO=care@yourdomain.com
# Optional: home review form (reviews.html) — defaults to ENQUIRY_NOTIFY_TO if unset
# HOME_REVIEW_NOTIFY_TO=care@yourdomain.com
APPLICATION_NOTIFY_TO=hr@yourdomain.com

# ── Vercel Blob (CV uploads) ────────────────────────────────────────────────
# Create a Blob store in Vercel → Storage; token is auto-injected or set manually
BLOB_READ_WRITE_TOKEN=

# ── Sentry (optional server error reporting) ────────────────────────────────
SENTRY_DSN=

# ── Vercel KV (Redis) ───────────────────────────────────────────────────────
# These are automatically injected by Vercel when you link a KV store.
# For local development, you can get these from your Vercel KV dashboard.
# https://vercel.com/docs/storage/vercel-kv/quickstart
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
