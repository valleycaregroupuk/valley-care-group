# Valley Care Group — Backend Environment Variables
# Copy to .env for local development. On Cloud Run use Secret Manager / env vars.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3500

# JWT — required in production (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-before-going-live

# Admin password — min 12 chars in production; hash stored in PostgreSQL
ADMIN_PASSWORD=vcg2025

# Local dev: RESET_ADMIN_HASH=1 once after password change
# RESET_ADMIN_HASH=1

NODE_ENV=development

# ── PostgreSQL (Cloud SQL) ────────────────────────────────────────────────
# Required in production. If unset, the API uses an in-memory store (dev only).
# Cloud Run: use Unix socket form, e.g.
# postgresql://USER:PASSWORD@/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=

# Local Postgres: use DATABASE_SSL=0
# DATABASE_SSL=0

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins. Example: https://your-site.web.app,https://www.example.com
ALLOWED_ORIGIN=

# ── Notifications ─────────────────────────────────────────────────────────────
# Recipient for care enquiries and job applications
ENQUIRY_NOTIFY_TO=valleycaregroupuk@gmail.com
APPLICATION_NOTIFY_TO=valleycaregroupuk@gmail.com

# ── Resend ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# ── Google Cloud Storage (CV uploads) ─────────────────────────────────────────
# Bucket in europe-west2 (or your region). Cloud Run service account needs storage.objectAdmin on bucket.
GCS_BUCKET_NAME=

# Optional: custom base URL for public objects (CDN or custom domain)
# GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/your-bucket

# Set to 1 if objects should be world-readable (public bucket policy or object ACL)
# GCS_MAKE_PUBLIC=1

# Use long-lived signed URLs instead of public (if bucket is private)
# GCS_USE_SIGNED_URL=1

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
